# Server
PORT=3000
BASE_URL=http://localhost:3000
# Optional: absoluter DB-Pfad (für Render + Persistent Disk z.B. /var/data/orders.sqlite)
DB_PATH=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
ADMIN_API_KEY=

# Optional: Mapping offer_id -> Stripe Price-ID.
# Wenn nicht gesetzt, verwendet die App dynamische Preise (price_data) aus src/lib/offers.js.
# Hinweis: Falls gesetzt, muss es 1-zeiliges JSON sein (dotenv).
# STRIPE_PRICE_MAPPING_JSON={"beobachter":{"stripePriceId":"price_..."},"gluecksPost":{"stripePriceId":"price_..."}}

# Ringier Weiterleitung (nach erfolgreichem Stripe-Webhook)
RINGIERE_FORWARD_URL=https://example.com/ringier-forward
# optional
RINGIERE_FORWARD_API_KEY=

# E-Mail an sales@famillesuisse.ch nach erfolgreicher Zahlung (SMTP)
# Ohne SMTP_HOST wird nichts gesendet (Webhook bleibt erfolgreich).
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true bei Port 465 (SSL)
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@famillesuisse.ch
SALES_NOTIFICATION_TO=sales@famillesuisse.ch

