# Server
PORT=3000
BASE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mapping: offer_id -> Stripe Price-ID
# offer_id-Werte sind aus src/lib/offers.js (z.B. "beobachter", "gluecksPost", ...).
STRIPE_PRICE_MAPPING_JSON={
  "beobachter": { "stripePriceId": "price_..." },
  "gluecksPost": { "stripePriceId": "price_..." },
  "landLiebe": { "stripePriceId": "price_..." },
  "schweizerIllustrierte": { "stripePriceId": "price_..." },
  "tele": { "stripePriceId": "price_..." },
  "blick": { "stripePriceId": "price_..." },
  "sonntagsBlick": { "stripePriceId": "price_..." },
  "lIllustrE": { "stripePriceId": "price_..." }
}

# Ringier Weiterleitung (nach erfolgreichem Stripe-Webhook)
RINGIERE_FORWARD_URL=https://example.com/ringier-forward
# optional
RINGIERE_FORWARD_API_KEY=

