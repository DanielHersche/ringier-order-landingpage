# Server
PORT=3000
BASE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Mapping offer_id -> Stripe Price-ID.
# Wenn nicht gesetzt, verwendet die App dynamische Preise (price_data) aus src/lib/offers.js.
# Hinweis: Falls gesetzt, muss es 1-zeiliges JSON sein (dotenv).
# STRIPE_PRICE_MAPPING_JSON={"beobachter":{"stripePriceId":"price_..."},"gluecksPost":{"stripePriceId":"price_..."}}

# Ringier Weiterleitung (nach erfolgreichem Stripe-Webhook)
RINGIERE_FORWARD_URL=https://example.com/ringier-forward
# optional
RINGIERE_FORWARD_API_KEY=

