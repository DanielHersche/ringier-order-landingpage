<!doctype html>
<html lang="de">
  <head>
    <%- include('_head') %>
    <title>Bestellung</title>
  </head>
  <body>
    <%- include('_header', { currentPage: 'Bestellung' }) %>

    <main class="flex-grow">
      <div class="my-8">
        <div data-testid="ContentColumn" class="max-w-container grow grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4">
          <div class="col-span-full lg:col-start-2 lg:col-span-10">
            <div class="flex space-x-2 mb-8 mt-2 flex-wrap">
              <a class="text-ellipsis overflow-hidden whitespace-nowrap underline text-secondary-gray" href="/">Home</a>
              <span>&gt;</span>
              <span class="text-ellipsis overflow-hidden whitespace-nowrap text-secondary-gray">Bestellung</span>
            </div>

            <div class="grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4 py-10 lg:grid-cols-10">
              <div class="col-span-full">
                <%- include('_checkoutStepper', { currentStep: 2 }) %>
                <h1 class="text-2xl md:text-3xl font-bold mb-6">Bestellung</h1>

                <div class="free-text-component free-text-component-padded mb-6">
                  <h2 class="text-xl font-bold">Ihre Bestellung</h2>
                  <div class="mt-3 space-y-2">
                    <% for (const item of cartItemsDetailed) { %>
                      <div class="text-secondary-gray">
                        <span class="font-semibold text-secondary-gray"><%= item.quantity %> ×</span> <%= item.offer.name %> (
                        <span class="font-semibold"><%= item.lineTotalDisplay %></span>)
                      </div>
                    <% } %>
                  </div>
                </div>

                <form id="orderForm" class="bg-white rounded-radius-card border border-border-color p-6">
        <input type="hidden" name="cart_items_json" value="<%= cartItemsJson %>" />

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="first_name">Vorname</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="first_name" name="first_name" autocomplete="given-name" required />
                    </div>
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="last_name">Nachname</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="last_name" name="last_name" autocomplete="family-name" required />
                    </div>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="email">E-Mail</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="email" name="email" type="email" autocomplete="email" required />
                    </div>
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="phone">Telefon (optional)</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="phone" name="phone" autocomplete="tel" />
                    </div>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="street">Strasse</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="street" name="street" autocomplete="address-line1" required />
                    </div>
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="house_no">Hausnummer</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="house_no" name="house_no" autocomplete="address-line2" required />
                    </div>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="postal_code">PLZ</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="postal_code" name="postal_code" autocomplete="postal-code" required />
                    </div>
                    <div>
                      <label class="block text-sm text-secondary-gray mb-1 font-normal" for="city">Ort</label>
                      <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="city" name="city" autocomplete="address-level2" required />
                    </div>
                  </div>

        <input type="hidden" name="country" value="CH" />

                  <div class="mt-6 space-y-3">
                    <label class="flex items-start gap-2 text-secondary-gray">
                      <input class="mt-1" type="checkbox" name="consent_terms" value="1" required />
                      <span>AGB/Terms bestätigen</span>
                    </label>
                    <label class="flex items-start gap-2 text-secondary-gray">
                      <input class="mt-1" type="checkbox" name="consent_privacy" value="1" required />
                      <span>Datenschutz bestätigen</span>
                    </label>
                    <label class="flex items-start gap-2 text-secondary-gray">
                      <input class="mt-1" type="checkbox" name="gift_subscription" value="1" />
                      <span>Das Abonnement soll ein Geschenk sein</span>
                    </label>
                  </div>

                  <div id="giftAddressFields" class="mt-6 hidden">
                    <h3 class="text-lg font-semibold mb-4">Lieferadresse</h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_first_name">Vorname (Empfänger)</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_first_name" name="shipping_first_name" autocomplete="given-name" />
                      </div>
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_last_name">Nachname (Empfänger)</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_last_name" name="shipping_last_name" autocomplete="family-name" />
                      </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_street">Strasse</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_street" name="shipping_street" autocomplete="address-line1" />
                      </div>
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_house_no">Hausnummer</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_house_no" name="shipping_house_no" autocomplete="address-line2" />
                      </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_postal_code">PLZ</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_postal_code" name="shipping_postal_code" autocomplete="postal-code" />
                      </div>
                      <div>
                        <label class="block text-sm text-secondary-gray mb-1 font-normal" for="shipping_city">Ort</label>
                        <input class="w-full h-10 px-3 rounded-radius-input border border-border-color" id="shipping_city" name="shipping_city" autocomplete="address-level2" />
                      </div>
                    </div>

                    <input type="hidden" name="shipping_country" value="CH" />
                  </div>

                  <div id="formErrors" class="mt-4 text-red-700 font-semibold" role="alert"></div>

                  <div class="mt-6 flex flex-col md:flex-row gap-3">
                    <button class="relative min-w-[7.375rem] px-5 h-10 text-[0.9375rem] before:absolute before:block before:top-0 before:left-0 before:right-0 before:bottom-0 before:rounded-radius-button before:transition-all md:h-10 outline-none text-button-primary-text before:bg-button-primary-bg before:hover:brightness-hover-button" type="submit">
                      <span class="relative pointer-events-none">Weiter zur Zahlung</span>
                    </button>
                    <a class="underline text-secondary-gray self-center" href="/cart">Zurück zur Auswahl</a>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('_footer') %>

    <script>
      const form = document.getElementById('orderForm');
      const errorsEl = document.getElementById('formErrors');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorsEl.textContent = '';

        const payload = Object.fromEntries(new FormData(form).entries());

        // Checkbox fields are only present if checked; we send boolean-like values.
        payload.consent_terms = !!payload.consent_terms;
        payload.consent_privacy = !!payload.consent_privacy;
        payload.gift_subscription = !!payload.gift_subscription;

        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          if (data?.errors?.length) errorsEl.textContent = data.errors.join(' ');
          else errorsEl.textContent = data?.error || 'Fehler beim Absenden.';
          return;
        }

        const data = await res.json();
        window.location.href = `/pay?orderId=${encodeURIComponent(data.orderId)}`;
      });

      // Lieferadresse nur zeigen/validieren, wenn "Geschenk" aktiv ist.
      const giftCheckbox = form.querySelector('input[name=\"gift_subscription\"]');
      const giftFields = document.getElementById('giftAddressFields');

      function syncGiftFields() {
        const enabled = !!giftCheckbox?.checked;
        // Robust gegen fehlende Tailwind-"hidden"-Klasse: per inline style schalten.
        giftFields.classList.toggle('hidden', !enabled);
        giftFields.style.display = enabled ? 'block' : 'none';

        const requiredIds = [
          'shipping_first_name',
          'shipping_last_name',
          'shipping_street',
          'shipping_house_no',
          'shipping_postal_code',
          'shipping_city',
        ];

        for (const id of requiredIds) {
          const el = document.getElementById(id);
          if (!el) continue;
          el.required = enabled;
        }
      }

      giftCheckbox?.addEventListener('change', syncGiftFields);
      // Initialer Sync (z.B. bei "Back" / zurückgeladenem Formular)
      syncGiftFields();
    </script>
  </body>
</html>

