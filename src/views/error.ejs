<!doctype html>
<html lang="de">
  <head>
    <%- include('_head') %>
    <title>Fehler</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <%- include('_header', { currentPage: 'Fehler' }) %>

    <main class="flex-grow">
      <div class="my-8">
        <div data-testid="ContentColumn" class="max-w-container grow grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4">
          <div class="col-span-full lg:col-start-2 lg:col-span-10">
            <div class="grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4 py-10 lg:grid-cols-10">
              <div class="col-span-full">
                <h1 class="text-2xl md:text-3xl font-bold mb-6">Fehler</h1>
                <div class="bg-white rounded-radius-card border border-border-color p-6">
                  <p class="text-secondary-gray"><%= message || 'Unbekannter Fehler.' %></p>
                  <div class="mt-6">
                    <a class="underline text-secondary-gray" href="/">Zurück zur Auswahl</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('_footer') %>
  </body>
</html>

