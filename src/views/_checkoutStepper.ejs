<%
  const step = Math.max(1, Math.min(3, Number(currentStep || 1)));
  const steps = [
    { idx: 1, label: 'Warenkorb' },
    { idx: 2, label: 'Adressen' },
    { idx: 3, label: 'Bestätigung' },
  ];
%>

<div class="mb-6" aria-label="Checkout Schritte">
  <div class="flex items-center justify-center gap-10 text-sm whitespace-nowrap">
    <% for (let i = 0; i < steps.length; i++) { const s = steps[i]; const isActive = s.idx === step; %>
      <div class="<%= isActive ? 'font-semibold text-header-text' : 'text-secondary-gray' %>">
        <span class="mr-2"><%= s.idx %></span><span><%= s.label %></span>
      </div>

      <% if (i < steps.length - 1) { %>
        <div class="text-secondary-gray text-xl leading-none px-2" aria-hidden="true">&gt;</div>
      <% } %>
    <% } %>
  </div>
</div>

