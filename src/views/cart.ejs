<!doctype html>
<html lang="de">
  <head>
    <%- include('_head') %>
    <title>Warenkorb</title>
  </head>
  <body>
    <%- include('_header', { currentPage: 'Warenkorb' }) %>

    <main class="flex-grow">
      <div class="my-8">
        <div data-testid="ContentColumn" class="max-w-container grow grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4">
          <div class="col-span-full lg:col-start-2 lg:col-span-10">
            <!-- Steps -->
            <div class="flex items-center gap-3 mb-6">
              <div class="font-semibold">1</div>
              <div class="text-secondary-gray">Warenkorb</div>
              <div class="text-secondary-gray">2</div>
              <div class="text-secondary-gray">Bestellung</div>
              <div class="text-secondary-gray">3</div>
              <div class="text-secondary-gray">Bestätigung</div>
            </div>

            <h1 class="text-2xl md:text-3xl font-bold mb-6">Ihr Warenkorb</h1>

            <% if (info === 'already') { %>
              <div class="mb-4 bg-secondary-gray/10 border border-border-color text-secondary-gray rounded-radius-card p-4 font-semibold">
                Bereits im Warenkorb: <%= infoOfferName %>
              </div>
            <% } %>

            <div class="bg-white rounded-radius-card border border-border-color p-6">
              <div class="grid grid-cols-4 gap-4 pb-4 border-b border-border-color text-secondary-gray text-sm">
                <div>Anzahl</div>
                <div>Preis</div>
                <div class="text-right">Summe</div>
                <div class="text-right"> </div>
              </div>

              <% for (const item of items) { %>
                <div class="grid grid-cols-4 gap-4 py-4 items-center border-b border-border-color">
                  <div class="font-semibold"><%= item.quantity %> × <%= item.offer.name %></div>
                  <div class="font-semibold"><%= item.offer.priceDisplay %></div>
                  <div class="font-semibold text-right"><%= item.lineTotalDisplay %></div>
                  <div class="text-right">
                    <a class="underline text-secondary-gray" href="/cart/remove?offer=<%= item.offerId %>">Entfernen</a>
                  </div>
                </div>
              <% } %>

              <div class="pt-4 border-t border-border-color flex justify-between items-center">
                <div class="text-secondary-gray">Summe</div>
                <div class="font-bold"><%= totalDisplay %></div>
              </div>

              <div class="mt-6 flex flex-col md:flex-row gap-3 justify-between">
                <a class="underline text-secondary-gray self-center" href="/">Weiter einkaufen</a>

                <a
                  class="relative inline-block min-w-[7.375rem] px-5 h-10 leading-10 text-[0.9375rem] before:absolute before:block before:top-0 before:left-0 before:right-0 before:bottom-0 before:rounded-radius-button before:transition-all outline-none text-button-primary-text before:bg-button-primary-bg before:hover:brightness-hover-button"
                  href="/form"
                >
                  <span class="relative pointer-events-none">Zur Kasse</span>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </main>

    <%- include('_footer') %>
  </body>
</html>

