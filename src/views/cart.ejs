<!doctype html>
<html lang="de">
  <head>
    <%- include('_head') %>
    <title>Warenkorb</title>
  </head>
  <body>
    <%- include('_header', { currentPage: 'Warenkorb' }) %>

    <main class="flex-grow">
      <div class="my-8">
        <div data-testid="ContentColumn" class="max-w-container grow grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4">
          <div class="col-span-full lg:col-start-2 lg:col-span-10">
            <%- include('_checkoutStepper', { currentStep: 1 }) %>

            <h1 class="text-2xl md:text-3xl font-bold mb-6">Ihr Warenkorb</h1>

            <% if (info === 'already') { %>
              <div class="mb-4 bg-secondary-gray/10 border border-border-color text-secondary-gray rounded-radius-card p-4 font-semibold">
                Bereits im Warenkorb: <%= infoOfferName %>
              </div>
            <% } %>

            <div class="bg-white rounded-radius-card border border-border-color p-6">
              <div
                class="grid items-center gap-4 pb-4 border-b border-border-color text-secondary-gray text-sm whitespace-nowrap"
                style="grid-template-columns: 100px minmax(0, 1fr) auto 6rem 40px;"
              >
                <div class="h-[100px]"> </div>
                <div class="min-w-0 truncate">Titel</div>
                <div class="whitespace-nowrap">Anzahl</div>
                <div class="whitespace-nowrap text-right">Preis</div>
                <div class="text-right"> </div>
              </div>

              <% for (const item of items) { %>
                <div
                  class="grid items-center gap-4 py-4 border-b border-border-color whitespace-nowrap"
                  style="grid-template-columns: 100px minmax(0, 1fr) auto 6rem 40px;"
                >
                  <div class="w-[100px] h-[100px] flex items-center">
                    <img
                      class="object-contain"
                      src="<%= item.offer.imageSrc %>"
                      alt="<%= item.offer.imageAlt %>"
                      style="height: 100px; width: 100px; object-fit: contain; display: block;"
                    />
                  </div>
                  <div class="font-semibold min-w-0 truncate">
                    <%= item.offer.name %>
                  </div>
                  <div class="font-semibold whitespace-nowrap"><%= item.quantity %></div>
                  <div class="font-semibold text-right whitespace-nowrap">
                    <%= item.offer.priceDisplay %>
                  </div>
                  <div class="text-right w-[40px]">
                    <a
                      class="text-secondary-gray hover:text-secondary-gray/80 transition-colors"
                      aria-label="Artikel aus dem Warenkorb entfernen"
                      href="/cart/remove?offer=<%= item.offerId %>"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18" />
                        <path d="M8 6V4h8v2" />
                        <path d="M19 6l-1 14H6L5 6" />
                        <path d="M10 11v6" />
                        <path d="M14 11v6" />
                      </svg>
                    </a>
                  </div>
                </div>
              <% } %>

              <div class="pt-4 border-t border-border-color flex justify-between items-center">
                <div class="text-secondary-gray">Summe</div>
                <div class="font-bold"><%= totalDisplay %></div>
              </div>

              <div class="mt-6 flex flex-col md:flex-row gap-3 justify-between">
                <a class="underline text-secondary-gray self-center" href="/">Weiter einkaufen</a>

                <a
                  class="relative inline-block min-w-[7.375rem] px-5 h-10 leading-10 text-[0.9375rem] before:absolute before:block before:top-0 before:left-0 before:right-0 before:bottom-0 before:rounded-radius-button before:transition-all outline-none text-button-primary-text before:bg-button-primary-bg before:hover:brightness-hover-button flex items-center justify-center"
                  href="/form"
                >
                  <span class="relative pointer-events-none block w-full text-center">Zur Kasse</span>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </main>

    <%- include('_footer') %>
  </body>
</html>

