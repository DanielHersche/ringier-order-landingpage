<!doctype html>
<html lang="de">
  <head>
    <%- include('_head') %>
    <title>Zahlung</title>
  </head>
  <body>
    <%- include('_header', { currentPage: 'Zahlung' }) %>

    <main class="flex-grow">
      <div class="my-8">
        <div data-testid="ContentColumn" class="max-w-container grow grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4">
          <div class="col-span-full lg:col-start-2 lg:col-span-10">
            <div class="flex space-x-2 mb-8 mt-2 flex-wrap">
              <a class="text-ellipsis overflow-hidden whitespace-nowrap underline text-secondary-gray" href="/">Home</a>
              <span>&gt;</span>
              <span class="text-ellipsis overflow-hidden whitespace-nowrap text-secondary-gray">Zahlung</span>
            </div>

            <div class="grid grid-cols-6 gap-x-2.5 md:grid md:grid-cols-12 md:gap-x-4 py-10 lg:grid-cols-10">
              <div class="col-span-full">
                <h1 class="text-2xl md:text-3xl font-bold mb-6">Zahlung</h1>

                <div class="bg-white rounded-radius-card border border-border-color p-6">
                  <div class="free-text-component free-text-component-padded mb-4">
                    <h2 class="text-xl font-bold">Zahlung</h2>
                    <div class="mt-3 space-y-2">
                      <% for (const item of orderItemsDetailed) { %>
                        <div class="text-secondary-gray">
                          <span class="font-semibold"><%= item.quantity %> ×</span> <%= item.offer.name %> (
                          <span class="font-semibold"><%= item.lineTotalDisplay %></span>)
                        </div>
                      <% } %>
                    </div>
                    <div class="mt-4 font-bold">
                      Total: <%= totalDisplay %>
                    </div>
                  </div>

                  <h3 class="text-lg font-semibold mb-3">Kundendaten</h3>
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                      <div class="text-sm text-secondary-gray">Name</div>
                      <div class="font-semibold"><%= order.first_name %> <%= order.last_name %></div>
                    </div>
                    <div>
                      <div class="text-sm text-secondary-gray">E-Mail</div>
                      <div class="font-semibold"><%= order.email %></div>
                    </div>
                    <div>
                      <div class="text-sm text-secondary-gray">Adresse</div>
                      <div class="font-semibold">
                        <%= order.street %> <%= order.house_no %><br />
                        <%= order.postal_code %> <%= order.city %><br />
                        <%= order.country %>
                      </div>
                    </div>
                  </div>

                  <% if (Number(order.gift_subscription) === 1) { %>
                    <h3 class="text-lg font-semibold mb-3 mt-6">Empfänger (Lieferadresse)</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                      <div>
                        <div class="text-sm text-secondary-gray">Name</div>
                        <div class="font-semibold">
                          <%= order.shipping_first_name %> <%= order.shipping_last_name %>
                        </div>
                      </div>
                      <div>
                        <div class="text-sm text-secondary-gray">Adresse</div>
                        <div class="font-semibold">
                          <%= order.shipping_street %> <%= order.shipping_house_no %><br />
                          <%= order.shipping_postal_code %> <%= order.shipping_city %><br />
                          <%= order.shipping_country %>
                        </div>
                      </div>
                      <div>
                        <div class="text-sm text-secondary-gray">Hinweis</div>
                        <div class="font-semibold">Das Abonnement soll ein Geschenk sein</div>
                      </div>
                    </div>
                  <% } %>

                  <div id="payErrors" class="mt-4 text-red-700 font-semibold" role="alert"></div>

                  <div class="mt-6 flex flex-col md:flex-row gap-3">
                    <button class="relative min-w-[7.375rem] px-5 h-10 text-[0.9375rem] before:absolute before:block before:top-0 before:left-0 before:right-0 before:bottom-0 before:rounded-radius-button before:transition-all md:h-10 outline-none text-button-primary-text before:bg-button-primary-bg before:hover:brightness-hover-button" id="payBtn" type="button">
                      <span class="relative pointer-events-none">Jetzt zur Zahlung</span>
                    </button>
                    <a class="underline text-secondary-gray self-center" href="/cart">Zurück</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('_footer') %>

    <script>
      const payBtn = document.getElementById('payBtn');
      const errorsEl = document.getElementById('payErrors');

      async function redirectToStripe() {
        errorsEl.textContent = '';
        payBtn.disabled = true;
        const originalBtnText = payBtn.textContent;
        payBtn.textContent = 'Bitte warten...';

        try {
          const res = await fetch('/api/orders/<%= order.id %>/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({}),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            errorsEl.textContent = data?.error || 'Fehler beim Erstellen der Zahlung.';
            payBtn.disabled = false;
            payBtn.textContent = originalBtnText || 'Jetzt zur Zahlung';
            return;
          }

          const data = await res.json();
          if (data?.checkoutUrl) {
            window.location.href = data.checkoutUrl;
            return;
          }

          errorsEl.textContent = 'Stripe Checkout URL fehlt.';
          payBtn.disabled = false;
          payBtn.textContent = originalBtnText || 'Jetzt zur Zahlung';
        } catch (err) {
          errorsEl.textContent = 'Fehler beim Kontakt zu Stripe.';
          payBtn.disabled = false;
          payBtn.textContent = originalBtnText || 'Jetzt zur Zahlung';
        }
      }

      // Auto-Redirect: beim Betreten der /pay-Seite direkt Stripe öffnen.
      window.addEventListener('DOMContentLoaded', () => {
        // Falls jemand "Zurück" und nochmal "Weiter" klickt, soll es immer funktionieren.
        redirectToStripe();
      });

      // Fallback: falls Auto-Redirect blockiert wird, kann man manuell klicken.
      payBtn.addEventListener('click', redirectToStripe);
    </script>
  </body>
</html>

